#!/bin/sh
### BEGIN INIT INFO
# Provides:          aesdsocket
# Required-Start:    $network $remote_fs $syslog
# Required-Stop:     $network $remote_fs $syslog
# Default-Start:     2 3 4 5
# Default-Stop:      0 1 6
# Short-Description: aesdsocket server
# Description:       Starts/stops the aesdsocket stream socket server
###                  which listens on port 9000, in daemon mode.
### END INIT INFO
#
# aesdsocket-start-stop
#
# start-stop-daemon wrapper for the aesdsocket application.
#
#   start : starts aesdsocket in daemon mode (-d). aesdsocket itself
#           forks and detaches after successfully binding to port 9000,
#           so no --background flag is needed here.
#   stop  : sends SIGTERM to the running aesdsocket daemon so it can
#           gracefully close any open connection, close its listening
#           socket, and delete /var/tmp/aesdsocketdata before exiting.
#

DAEMON=/usr/bin/aesdsocket
DAEMON_ARGS="-d"
NAME=aesdsocket
PIDFILE=/var/run/aesdsocket.pid

case "$1" in
    start)
        echo "Starting $NAME"
        start-stop-daemon --start --oknodo --exec $DAEMON -- $DAEMON_ARGS
        ;;
    stop)
        echo "Stopping $NAME"
        start-stop-daemon --stop --oknodo --signal TERM --name $NAME --retry TERM/10/KILL/5
        ;;
    restart)
        $0 stop
        sleep 1
        $0 start
        ;;
    *)
        echo "Usage: $0 {start|stop|restart}"
        exit 1
        ;;
esac

exit 0
